SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
# regex-only (default) | ollama | fake. No third-party AI API is contacted under
# any configuration reachable from these defaults. ollama runs local inference on
# infrastructure you control — fully implemented and selectable, but not the
# shipped default (the accuracy eval measured clean-subset false blocks with
# gemma4:12b; see config.py's comment for details). A deployment explicitly
# configured for ollama that can't reach the configured host at startup runs as
# declared regex-only for its whole process lifetime instead (see the /health
# endpoint).
CLASSIFIER_PROVIDER=regex-only
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:12b
CORS_EXTRA_ORIGINS=
DECISION_API_KEY=test-internal-key
